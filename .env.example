# Database Setup (Targeting local PostgreSQL on port 5432)
# Adjust the password 'postgres' if your local instance requires a different password
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opencms?schema=public"

# Authentication JWT encryption secret key
JWT_SECRET="opencms-super-secret-key-change-this-in-production-2026"

# Host Domain
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
